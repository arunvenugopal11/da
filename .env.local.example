# da — local development environment variables
# Copy to .env.local and fill in values. Never commit .env.local.
# In production, secrets come from HCP Vault Secrets → SSM Parameter Store.

ENV_NAME=local

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://da_admin:devpassword123@localhost:5432/datingapp

# ── AWS Local (Docker containers) ────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_ENDPOINT=http://localhost:8000
SQS_ENDPOINT=http://localhost:9324
SQS_NOTIFICATION_QUEUE_URL=http://localhost:9324/000000000000/da-dev-notification
SQS_MATCHING_QUEUE_URL=http://localhost:9324/000000000000/da-dev-matching

# ── App secrets ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=local-dev-jwt-secret-replace-with-real-random-string

# From https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# From https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_PUSH_TOKEN=REPLACE_ME

# From RevenueCat dashboard
REVENUECAT_WEBHOOK_SECRET=REPLACE_ME

# ── Ports ─────────────────────────────────────────────────────────────────
API_PORT=4000
CHAT_WS_PORT=4001